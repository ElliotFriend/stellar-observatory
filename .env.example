# Default network: "stellar:testnet" or "stellar:pubnet"
PUBLIC_STELLAR_NETWORK=stellar:testnet

# Server-side only
PAYTO_ADDRESS=GDNB6ZWJ4HV5EMJYPJNTHTEMUJVFOHZX6VJE34KZGWKF4UQDJ7UCEQIO

# Per-network facilitator config
# Testnet defaults to https://x402.org/facilitator if not set
TESTNET_FACILITATOR_URL=https://x402.org/facilitator
# TESTNET_FACILITATOR_API_KEY=

# Pubnet defaults to https://x402.org/facilitator if not set
# PUBNET_FACILITATOR_URL=
# PUBNET_FACILITATOR_API_KEY=

# Per-network RPC URLs (optional — sensible testnet defaults are built in)
# Testnet defaults to https://soroban-testnet.stellar.org
# PUBLIC_TESTNET_RPC_URL=https://soroban-testnet.stellar.org
# PUBLIC_PUBNET_RPC_URL=https://rpc.lightsail.network

# Secret to bypass paywall for testing (e.g. /api/space-weather?bypass=mysecret)
# BYPASS_PAYMENT_SECRET=
