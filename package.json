{
    "name": "stellar-observatory",
    "private": true,
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "prepare": "svelte-kit sync || echo ''",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "test:unit": "vitest",
        "test": "pnpm run test:unit -- --run",
        "lint": "prettier --check . && eslint . && pnpm openapi:check",
        "format": "prettier --write .",
        "openapi:write": "tsx scripts/write-openapi.ts",
        "openapi:check": "pnpm openapi:write && git diff --exit-code openapi.generated.json"
    },
    "devDependencies": {
        "@eslint/compat": "^2.1.0",
        "@eslint/js": "^10.0.1",
        "@sveltejs/adapter-vercel": "^6.3.3",
        "@sveltejs/kit": "^2.59.1",
        "@sveltejs/vite-plugin-svelte": "^7.1.2",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/vite": "^4.2.4",
        "@types/node": "^25.6.2",
        "@vitest/browser-playwright": "^4.1.5",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.17.1",
        "globals": "^17.6.0",
        "playwright": "^1.59.1",
        "prettier": "^3.8.3",
        "prettier-plugin-svelte": "^3.5.1",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "svelte": "^5.55.5",
        "svelte-check": "^4.4.8",
        "tailwindcss": "^4.2.4",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.2",
        "vite": "^8.0.11",
        "vitest": "^4.1.5",
        "vitest-browser-svelte": "^2.1.1"
    },
    "dependencies": {
        "@asteasolutions/zod-to-openapi": "^8.5.0",
        "@creit-tech/stellar-wallets-kit": "jsr:^2.1.0",
        "@x402/core": "^2.11.0",
        "@x402/stellar": "^2.11.0",
        "x402-sveltekit": "^0.1.8",
        "zod": "^4.4.3"
    }
}
